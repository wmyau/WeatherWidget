<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/color_widget_background"
    android:paddingLeft="8dp"
    android:paddingRight="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.3"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textColor="@color/color_widget_text_primary"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:contentDescription="@string/loading" />

        <TextClock
            android:id="@+id/tv_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:format12Hour="h:mm a"
            android:format24Hour="HH:mm"
            android:textColor="@color/color_widget_text_clock"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/color_widget_text_date"
            android:textSize="11sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_day_0"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Today\n☀\n--°/--°"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_day_1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Tue\n⛅\n--°/--°"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_day_2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Wed\n☁\n--°/--°"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_day_3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Thu\n☂\n--°/--°"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_day_4"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Fri\n⛅\n--°/--°"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_day_5"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Sat\n☀\n--°/--°"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_day_6"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Sun\n⛅\n--°/--°"
        android:textColor="@color/color_widget_text_primary"
        android:textSize="12sp" />

</LinearLayout>
